GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
ELEVENLABS_STT_MODEL_ID=scribe_v2_realtime
ELEVENLABS_STT_LANGUAGE_CODE=

# TTS backend: custom (GPU sidecar) or elevenlabs
TTS_BACKEND=custom
TTS_MODEL_ID=C:\Model
TTS_SERVICE_URL=http://localhost:8100
TTS_LOAD_IN_4BIT=true
TTS_DEFAULT_LANGUAGE=hindi
TTS_DEFAULT_SPEAKER=159
TTS_SAMPLE_RATE=24000
HF_TOKEN=

AUDIO_SAMPLE_RATE=16000

HOST=0.0.0.0
PORT=8000

VAD_MODEL_PATH=models/silero_vad.onnx
VAD_FRAME_MS=30
VAD_PRE_SPEECH_MS=300
VAD_MIN_SPEECH_MS=300
# Lower = faster endpoint, more cut-offs (latency tuning)
VAD_END_SILENCE_MS=400
VAD_MAX_UTTERANCE_MS=25000
VAD_SPEECH_THRESHOLD=0.5

# Lower = earlier first spoken audio (latency tuning)
TTS_MIN_CHARS=6
TTS_SEGMENT_TIMEOUT_MS=100
STT_COMMIT_TIMEOUT_S=15
