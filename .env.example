# ── LLM ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# ── ElevenLabs (STT; optional TTS fallback) ─────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
ELEVENLABS_STT_MODEL_ID=scribe_v2_realtime

# ── Sarvam (optional alternate STT — not wired by default) ──────────────────
SARVAM_API_KEY=
SARVAM_MODEL=saaras:v3
SARVAM_MODE=transcribe
SARVAM_LANGUAGE_CODE=
SARVAM_SAMPLE_RATE=16000

# ── Main app server ─────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── TTS (main app) ───────────────────────────────────────────────────────────
TTS_BACKEND=custom
# Local sidecar:  http://localhost:8100
# Remote RunPod:  https://your-pod-id-8100.proxy.runpod.net
TTS_SERVICE_URL=http://localhost:8100
TTS_MODE=single
# slow_gpu | balanced | fast_gpu  (see README latency profiles)
TTS_LATENCY_PROFILE=fast_gpu

# Sidecar model path (local dev only; on RunPod set on the pod)
TTS_MODEL_ID=C:\Model
TTS_LOAD_IN_4BIT=true
TTS_USE_UNSLOTH=false

# ── VAD ─────────────────────────────────────────────────────────────────────
VAD_END_SILENCE_MS=250

# ── Sidecar-only (set on GPU host / RunPod pod .env) ─────────────────────────
# TTS_DECODE_MODE=cumulative
# TTS_STREAM_DECODE_FRAMES=2
# TTS_PCM_CHUNK_MS=200
# TTS_MAX_NEW_TOKENS=384
# TTS_AUDIO_TOKENS_PER_CHAR=18
# TTS_HOST=0.0.0.0
# TTS_PORT=8100
# HF_TOKEN=
